# Copy to .env (`cp .env.example .env`). Loaded by the Justfile (`set dotenv-load`),
# read by tempo for dev ports, and by the server (pacman-server) via dotenvy.

# Dev ports (sequential; PACMAN_WEB_PORT is the user-facing one).
# Used by `just dev`/`tempo dev` and the Vite proxy. If only PACMAN_WEB_PORT is set,
# the others derive from it (server = web+1, db = web+2).
PACMAN_WEB_PORT=42565
PACMAN_SERVER_PORT=42566
PACMAN_DB_PORT=42567

# Server (pacman-server).
# DATABASE_URL is (re)written by `tempo db`. Comment it out to use the SQLite in-memory fallback.
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:42567/pacman
# JWT_SECRET and PUBLIC_BASE_URL are required. These dev defaults are insecure -- never use them in production.
JWT_SECRET=dev-insecure-jwt-secret-change-me
PUBLIC_BASE_URL=http://localhost:42565
HOST=127.0.0.1

# OAuth (optional; set BOTH halves of a provider to enable it).
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# S3 image storage (optional; set ALL five to enable).
S3_ACCESS_KEY=
S3_SECRET_ACCESS_KEY=
S3_ACCOUNT_ID=
S3_BUCKET_NAME=
S3_PUBLIC_BASE_URL=
